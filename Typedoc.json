{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/**/*.ts", "src/**/*.tsx"],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "name": "ART SAFE PLACE — API Documentation",
  "readme": "none",
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "node_modules/**"
  ],
  "excludePrivate": true,
  "excludeInternal": true,
  "includeVersion": true,
  "plugin": ["typedoc-plugin-markdown"],
  "theme": "default"
}